{
  "permissions": {
    "allow": [
      "Bash(npm create:*)",
      "Read(//usr/local/**)",
      "Read(//usr/**)",
      "Bash(command -v node)",
      "Read(//c/Program Files/**)",
      "Read(//c/Program Files \\(x86\\)/**)",
      "Bash(cmd.exe /c \"where node\")",
      "Bash(cmd.exe /c \"node --version\")",
      "Bash(cmd.exe /c \"node --version && npm --version\")",
      "Bash(cmd.exe /c \"where node 2>&1\")"
    ]
  }
}
